APP_DOMAIN=app.example.com
ADMIN_DOMAIN=admin.example.com
NGINX_HTTP_PORT=80

WEB_ORIGIN=https://app.example.com
ADMIN_ORIGIN=https://admin.example.com
NEXT_PUBLIC_API_BASE_URL=https://app.example.com/api
WEB_INTERNAL_API_BASE_URL=http://api:4000/api
VITE_API_BASE_URL=https://app.example.com/api

WEB_BRAND_NAME=Laws
ADMIN_BRAND_NAME=Laws Admin
AUTH_COOKIE_NAME=laws_session

POSTGRES_USER=laws
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=laws

DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

LOG_LVL=info
SWAGGER_ENABLED=false

JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
USER_KEY_ENC_SECRET=replace_me_with_32_byte_base64_value

OPENAI_DEFAULT_MODEL=gpt-4.1
OPENAI_FALLBACK_API_KEY=

CODEX_BINARY=codex
CODEX_HOME_ROOT=/var/lib/laws/codex/users
CODEX_WORKSPACE_ROOT=/var/lib/laws/codex/workspaces
CODEX_MAX_CONCURRENT=5
CODEX_MAX_CONCURRENT_PER_USER=1
CODEX_LOGIN_TIMEOUT_MS=300000
CODEX_RUN_TIMEOUT_MS=600000
CODEX_SANDBOX=workspace-write
