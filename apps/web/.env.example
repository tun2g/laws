# ============================================================
# apps/web .env example
# Copy to apps/web/.env.local for local dev.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ============================================================

# Browser-facing API base (CORS-allowed origin on the API)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Server-side API base (used in server components / route handlers)
API_BASE_URL=http://localhost:4000/api

# Cookie name for the auth session (set by the web's /api/auth/login)
AUTH_COOKIE_NAME=laws_session

# Brand name shown in the UI
NEXT_PUBLIC_BRAND_NAME=Laws
