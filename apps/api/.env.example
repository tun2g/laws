# ============================================================
# apps/api .env example
# Copy to apps/api/.env and fill in.
# ============================================================
NODE_ENV=development
APP_PORT=4000
LOG_LVL=debug
SWAGGER_ENABLED=true

# Public URLs of front-ends — used for CORS allow-list
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# Database — match docker-compose values at repo root
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=laws
DATABASE_USERNAME=laws
DATABASE_PASSWORD=laws_dev_password
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

# JWT
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Crypto key for encrypting per-user OpenAI keys at rest.
# Generate with: openssl rand -base64 32
USER_KEY_ENC_SECRET=replace_me_with_32_byte_base64_value

# Default OpenAI model used for research/review when the user does not override
OPENAI_DEFAULT_MODEL=gpt-4.1

# OPTIONAL system-wide OpenAI key — used only as a fallback when admin grants
# "shared key" access to a user. Normally each user supplies their own key.
OPENAI_FALLBACK_API_KEY=
