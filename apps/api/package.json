{
  "name": "@laws/api",
  "version": "0.0.1",
  "description": "Laws API — NestJS backend (Vietnamese legal research workflows)",
  "private": true,
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "typeorm:dev": "node -r tsconfig-paths/register ./node_modules/typeorm/cli-ts-node-commonjs.js",
    "typeorm:prod": "node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm:dev --dataSource=src/database/data-source.ts migration:generate src/database/migrations/auto-generate",
    "migration:create": "pnpm typeorm:dev migration:create",
    "migration:run": "pnpm migration:run:dev",
    "migration:run:dev": "pnpm typeorm:dev --dataSource=src/database/data-source.ts migration:run",
    "migration:run:prod": "pnpm typeorm:prod --dataSource=dist/database/data-source.js migration:run",
    "migration:revert:dev": "pnpm typeorm:dev --dataSource=src/database/data-source.ts migration:revert",
    "migration:revert:prod": "pnpm typeorm:prod --dataSource=dist/database/data-source.js migration:revert",
    "schema:drop": "pnpm typeorm:dev --dataSource=src/database/data-source.ts schema:drop",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@laws/shared": "workspace:*",
    "@laws/skill-prompts": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "docx": "^9.0.3",
    "dotenv": "^17.3.1",
    "helmet": "^8.0.0",
    "nestjs-pino": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/multer": "^1.4.12",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
