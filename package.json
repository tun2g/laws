{
  "name": "laws",
  "private": true,
  "version": "0.0.1",
  "description": "Web app for non-tech Vietnamese lawyers to run AI legal research workflows (cclaws ported to a friendly web UI).",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20.10 <24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
